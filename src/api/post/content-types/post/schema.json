{
  "kind": "collectionType",
  "collectionName": "posts",
  "info": {
    "singularName": "post",
    "pluralName": "posts",
    "displayName": "Post"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "title": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "excerpt": {
      "type": "text",
      "required": false
    },
    "category": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::page.page"
    },
    "blocks": {
      "type": "dynamiczone",
      "components": [
        "blocks.rich-text",
        "blocks.hero",
        "blocks.header",
        "blocks.carousel",
        "blocks.list",
        "blocks.form",
        "blocks.cta"
      ]
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    }
  }
}
